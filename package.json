{
  "name": "angular-lab",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.1"
  },
  "scripts": {
    "ng": "ng",
    "dev": "vite",
    "start": "pnpm run dev",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "watch": "vite build --watch",
    "test:unit": "vitest run",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "install:vertex": "mkdir -p public/vertex-editor && curl -fsSL -o public/vertex-editor/web-editor.min.js https://github.com/Andersseen/vertex/releases/download/web-editor-latest/web-editor.min.js && curl -fsSL -o public/vertex-editor/web-editor-lite.min.js https://github.com/Andersseen/vertex/releases/download/web-editor-latest/web-editor-lite.min.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "node dist/analog/server/index.mjs"
  },
  "private": true,
  "dependencies": {
    "@analogjs/content": "^2.6.1",
    "@analogjs/router": "^2.6.1",
    "@angular/animations": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@tailwindcss/vite": "^4.1.4",
    "@voltui/components": "^0.2.0",
    "angular-movement": "^0.4.0",
    "front-matter": "^4.0.2",
    "h3": "^1.13.0",
    "marked": "^15.0.7",
    "marked-gfm-heading-id": "^4.1.1",
    "marked-highlight": "^2.2.1",
    "marked-mangle": "^1.1.10",
    "postcss": "^8.5.3",
    "prismjs": "^1.29.0",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.6.1",
    "@analogjs/vite-plugin-angular": "^2.6.1",
    "@analogjs/vitest-angular": "^2.6.1",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/angular": "^17.2.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "angular-eslint": "^22.0.0",
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "jsdom": "^22.0.0",
    "playwright": "^1.52.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^4.1.0",
    "zone.js": "^0.15.0"
  },
  "overrides": {
    "vite": "$vite",
    "vitest": "$vitest",
    "@angular/common": "$@angular/common",
    "@angular/core": "$@angular/core"
  }
}
